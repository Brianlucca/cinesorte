{
  "rewrites": [
    {
      "source": "/share/:type/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(whatsapp|telegrambot|twitterbot|facebookexternalhit|facebookcatalog|discordbot|linkedinbot|slackbot|viber|skype|googlebot|bingbot|applebot|duckduckbot|yandexbot|pinterestbot|snapchat|embedly|outbrain|quora|vkshare|w3c_validator|xing-contenttabreceiver|preview|crawler|spider|bot).*"
        }
      ],
      "destination": "/api/share?type=:type&id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
